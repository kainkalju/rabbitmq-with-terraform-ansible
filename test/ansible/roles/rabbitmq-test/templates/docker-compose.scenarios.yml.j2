services:

  # ── Scenario 1: Work Queues ───────────────────────────────────────────────
  s1-producer:
    build:
      context: ./scenarios
      dockerfile: s1_work_queues/Dockerfile
    restart: unless-stopped
    environment:
      RABBITMQ_HOSTS: "{{ rabbitmq_hosts | join(',') }}"
      RABBITMQ_USER: "{{ rabbitmq_user }}"
      RABBITMQ_PASS: "{{ rabbitmq_password }}"
      QUEUE_NAME: "work.tasks"
      PUBLISH_INTERVAL_SECONDS: "1"

  s1-worker-1:
    build:
      context: ./scenarios
      dockerfile: s1_work_queues/Dockerfile
    command: ["python", "-u", "worker.py"]
    restart: unless-stopped
    environment:
      RABBITMQ_HOSTS: "{{ rabbitmq_hosts | join(',') }}"
      RABBITMQ_USER: "{{ rabbitmq_user }}"
      RABBITMQ_PASS: "{{ rabbitmq_password }}"
      QUEUE_NAME: "work.tasks"

  s1-worker-2:
    build:
      context: ./scenarios
      dockerfile: s1_work_queues/Dockerfile
    command: ["python", "-u", "worker.py"]
    restart: unless-stopped
    environment:
      RABBITMQ_HOSTS: "{{ rabbitmq_hosts | join(',') }}"
      RABBITMQ_USER: "{{ rabbitmq_user }}"
      RABBITMQ_PASS: "{{ rabbitmq_password }}"
      QUEUE_NAME: "work.tasks"

  s1-worker-3:
    build:
      context: ./scenarios
      dockerfile: s1_work_queues/Dockerfile
    command: ["python", "-u", "worker.py"]
    restart: unless-stopped
    environment:
      RABBITMQ_HOSTS: "{{ rabbitmq_hosts | join(',') }}"
      RABBITMQ_USER: "{{ rabbitmq_user }}"
      RABBITMQ_PASS: "{{ rabbitmq_password }}"
      QUEUE_NAME: "work.tasks"

  # ── Scenario 2: Publish/Subscribe ─────────────────────────────────────────
  s2-producer:
    build:
      context: ./scenarios
      dockerfile: s2_pubsub/Dockerfile
    restart: unless-stopped
    environment:
      RABBITMQ_HOSTS: "{{ rabbitmq_hosts | join(',') }}"
      RABBITMQ_USER: "{{ rabbitmq_user }}"
      RABBITMQ_PASS: "{{ rabbitmq_password }}"
      EXCHANGE_NAME: "logs"
      PUBLISH_INTERVAL_SECONDS: "1"

  s2-consumer-1:
    build:
      context: ./scenarios
      dockerfile: s2_pubsub/Dockerfile
    command: ["python", "-u", "consumer.py"]
    restart: unless-stopped
    environment:
      RABBITMQ_HOSTS: "{{ rabbitmq_hosts | join(',') }}"
      RABBITMQ_USER: "{{ rabbitmq_user }}"
      RABBITMQ_PASS: "{{ rabbitmq_password }}"
      EXCHANGE_NAME: "logs"

  s2-consumer-2:
